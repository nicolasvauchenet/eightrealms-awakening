{% extends 'front_office/_layout/_index.html.twig' %}

{% block title %}Bienvenue dans les Hut Royaumes, Aventurier !{% endblock %}

{% block body_class %}front-office home{% endblock %}

{% block main %}
    <section class="app-section">
        {% if app.user %}
            <p>
                <a href="{{ path('app_front_office_profile') }}" class="app-button outline">
                    <small>{{ app.user.name }}</small>
                    Mon Compte
                </a>
            </p>

            {% if app.user.character %}
                <p>
                    <a href="{{ path('app_game_character_sheet_player', {'back' : 'accueil'}) }}" class="app-button">
                        <small>{{ app.user.character.name }}</small>
                        Personnage
                    </a>
                </p>

                {% if app.user.character.location %}
                    <p>
                        <a href="{{ path('app_game_home') }}" class="app-button cta">
                            <small>Reprendre</small>
                            {{ app.user.character.location.name }}
                        </a>
                    </p>
                {% else %}
                    <p>
                        <a href="{{ path('app_game_home') }}" class="app-button cta">
                            <small>Nouvelle</small>
                            Aventure
                        </a>
                    </p>
                {% endif %}
            {% else %}
                <p>
                    <a href="{{ path('app_game_character_create_home') }}" class="app-button cta">
                        <small>Nouveau</small>
                        Personnage
                    </a>
                </p>
            {% endif %}
        {% else %}
            <p>
                <a href="{{ path('app_front_office_register') }}" class="app-button">
                    <small>Nouveau Joueur</small>
                    Inscription
                </a>
            </p>

            <p>
                <a href="{{ path('app_login') }}" class="app-button cta">
                    <small>Déjà inscrit</small>
                    Connexion
                </a>
            </p>
        {% endif %}
    </section>
{% endblock %}
