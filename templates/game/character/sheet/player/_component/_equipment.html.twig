                    <div class="gauge">
                        <div class="gauge-fill {% if characterItem.item.category.slug == 'arme-magique' %}info{% else %}success{% endif %}" style="--value: {{ app_itemService.health(characterItem) }}"></div>
                    </div>
                </a>
                {% include 'game/_layout/_character/_sheet/_tooltip/_item.html.twig' with {characterItem: characterItem} %}
            {% endif %}
        </div>

        <div class="equipped-item shield" data-controller="tooltip">
            <img src="{{ asset('img/core/equipment/shield.png') }}" class="placeholder" alt="Bouclier"/>
            {% set characterItem = app_characterItemService.equippedItems(character).shield %}
