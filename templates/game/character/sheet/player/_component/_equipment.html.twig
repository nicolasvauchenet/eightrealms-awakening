<div class="sheet-content equipment {% if this.activeContent == 'equipment' %}active{% endif %}">
    <h3 class="sheet-subtitle">Équipement</h3>

    <div class="equipped">
        <img src="{{ asset('img/core/equipment/equipment.png') }}" alt="Équipement"/>

        <div class="equipped-item armor" data-controller="tooltip">
            <img src="{{ asset('img/core/equipment/armor.png') }}" class="placeholder" alt="Armure"/>
            {% set characterItem = app_characterItemService.equippedItems(character).armor %}
            {% if characterItem %}
                <a href="#" data-action="click->tooltip#open">
                    <img src="{{ asset('img/core/item/armor/' ~ characterItem.item.picture) }}"
                         class="equip {% if characterItem.health is not null and characterItem.health <= 0 %}broken{% endif %}"
                         alt="{{ characterItem.item.name }}"/>
                    <div class="gauge">
                        <div class="gauge-fill success" style="--value: {{ app_itemService.health(characterItem) }}"></div>
                    </div>
                </a>
                {% include 'game/_layout/_character/_sheet/_tooltip/_item.html.twig' with {characterItem: characterItem} %}
            {% endif %}
        </div>

        <div class="equipped-item righthand" data-controller="tooltip">
            <img src="{{ asset('img/core/equipment/sword.png') }}" class="placeholder" alt="Main droite"/>
            {% set characterItem = app_characterItemService.equippedItems(character).righthand %}
            {% if characterItem %}
                <a href="#" data-action="click->tooltip#open">
                    <img src="{{ asset('img/core/item/weapon/' ~ characterItem.item.picture) }}"
                         class="equip {% if characterItem.health is not null and characterItem.health <= 0 %}broken{% endif %}"
                         alt="{{ characterItem.item.name }}"/>
                    <div class="gauge">
                        <div class="gauge-fill {% if characterItem.item.category.slug == 'arme-magique' %}info{% else %}success{% endif %}" style="--value: {{ app_itemService.health(characterItem) }}"></div>
                    </div>
                </a>
                {% include 'game/_layout/_character/_sheet/_tooltip/_item.html.twig' with {characterItem: characterItem} %}
            {% endif %}
        </div>

