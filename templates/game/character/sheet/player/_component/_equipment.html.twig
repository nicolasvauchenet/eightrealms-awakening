                {% endif %}
            </div>
        </div>

        <div class="equipped-item amulet" data-controller="tooltip">
            <img src="{{ asset('img/core/equipment/amulet.png') }}" class="placeholder" alt="Amulette"/>
            {% set characterItem = app_characterItemService.equippedItems(character).amulet %}
