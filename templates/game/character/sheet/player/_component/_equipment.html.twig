                         class="equip {% if characterItem.health is not null and characterItem.health <= 0 %}broken{% endif %}"
                         alt="{{ characterItem.item.name }}"/>
                    <div class="gauge">
                        <div class="gauge-fill success" style="--value: {{ app_itemService.health(characterItem) }}"></div>
                    </div>
                </a>
                {% include 'game/_layout/_character/_sheet/_tooltip/_item.html.twig' with {characterItem: characterItem} %}
            {% endif %}
        </div>

        <div class="equipped-assets">
            <div class="equipped-asset ring" data-controller="tooltip">
                <img src="{{ asset('img/core/equipment/ring.png') }}" class="placeholder" alt="Anneau"/>
                {% set characterItem = app_characterItemService.equippedItems(character).ring %}
