{% extends 'game/_layout/_character/_sheet/_index.html.twig' %}

{% block title %}{{ character.name}} - Les Huit Royaumes - Chapitre I : L'Éveil{% endblock %}

{% block body_class %}game character sheet{% endblock %}

{% block main %}
    <a href="{{ path('app_game_character_create_home') }}"
       class="app-button back">
        {{ ux_icon('zondicons:close-solid', {'class': 'app-icon'}) }}
    </a>

    <section class="app-section">
        {{ component('PreGeneratedSheet', { character: character }) }}
    </section>
{% endblock %}
