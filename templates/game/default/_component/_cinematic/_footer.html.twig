<footer class="screen-footer">
    {% if this.previousScreen %}
        <button class="app-button cta" {{ live_action('changeScreen', {'id': this.previousScreen.id}) }}>
            Continuer
        </button>
    {% else %}
        {% for action in this.activeScreen.actions %}
            <button class="app-button cta" {{ live_action('doAction', {'id': action.id}) }}>
                {{ action.name }}
            </button>
        {% endfor %}
    {% endif %}
</footer>
