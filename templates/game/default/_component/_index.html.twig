<div {{ attributes.defaults(stimulus_controller('action')) }}>
    {% if this.activeScreenType == 'cinematic' %}
        {% include 'game/default/_component/_cinematic/_index.html.twig' %}
    {% elseif this.activeScreenType == 'location' %}
        {% include 'game/default/_component/_location/_index.html.twig' %}
    {% elseif this.activeScreenType == 'interaction' %}
        {% include 'game/default/_component/_interaction/_index.html.twig' %}
    {% elseif this.activeScreenType == 'trade' %}
        {% include 'game/default/_component/_trade/_index.html.twig' %}
    {% elseif this.activeScreenType == 'dialogue' %}
        {% include 'game/default/_component/_dialogue/_index.html.twig' %}
    {% elseif this.activeScreenType == 'combat' %}
