<div class="screen-footeractions">
    <button class="screen-action" title="{{ this.activeScreen.npc.name }}" {{ live_action('doAction', {'id': this.activeScreen.npc.id, 'type': 'interaction'}) }}>
        <img src="{{ asset('img/chapter1/npc/thumb_' ~ this.activeScreen.npc.picture) }}" alt="{{ this.activeScreen.npc.name }}"/>
    </button>

    <button class="screen-action" title="Partir" {{ live_action('doAction', {'type': 'exit'}) }}>
        <img src="{{ asset('img/core/action/exit.png') }}" alt="Partir"/>
    </button>
</div>
