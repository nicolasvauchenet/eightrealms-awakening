<div class="app-screen trade" data-loading="addClass(loading)">
    <img src="{{ asset('img/' ~ this.activeScreen.npc.picture) }}" class="app-wallpaper" alt="{{ this.activeScreen.npc.name }}"/>

    {% include 'game/default/_component/_trade/_header/_index.html.twig' %}

    {% if this.activeScreen.tradeType == 'trade' %}
        {% include 'game/default/_component/_trade/_main/_trade.html.twig' %}
    {% elseif this.activeScreen.tradeType == 'repair' %}
        {% include 'game/default/_component/_trade/_main/_repair.html.twig' %}
    {% elseif this.activeScreen.tradeType == 'reload' %}
        {% include 'game/default/_component/_trade/_main/_reload.html.twig' %}
    {% endif %}

    {% include 'game/default/_component/_trade/_footer/_index.html.twig' %}
</div>
