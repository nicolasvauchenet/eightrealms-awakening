<header class="screen-header">
    <div class="controls">
        <a href="{{ path('app_character_sheet', {'slug': app.user.player.slug, 'previousUrl': '/jeu'}) }}"
           class="control {% if this.characterUpdated %}blink{% endif %}">
            {{ ux_icon('game-icons:character', {'class': 'app-icon'}) }}
        </a>

        <a href="{{ path('app_game_map', {'slug': this.currentScene.place.location.slug, 'previousUrl': '/jeu'}) }}"
           class="control {% if this.mapUpdated %}blink{% endif %}">
            {{ ux_icon('solar:map-bold', {'class': 'app-icon'}) }}
        </a>
    </div>

    <div class="title">
        <h1>{{ this.currentScene.place.location.name }}</h1>
        <h2>{{ this.currentScene.place.name }}</h2>
    </div>

    <div class="controls">
        <a href="{{ path('app_home') }}"
           class="control bg-third"
           onclick="return window.confirm('Quitter la partie ?')">
            {{ ux_icon('streamline:emergency-exit-solid', {'class': 'app-icon'}) }}
        </a>
    </div>
</header>
