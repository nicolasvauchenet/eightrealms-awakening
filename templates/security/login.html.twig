{% extends '_layout/default/_index.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body_class %}sheet{% endblock %}

{% block main %}
    <form method="post" class="app-form">
        <fieldset class="form-fieldset">
            <legend class="form-legend">Vos Identifiants</legend>

            <div class="form-group">
                <label for="username" class="form-label required">Votre e-mail</label>
                <input type="email"
                       value="{{ last_username }}"
                       name="_username"
                       id="username"
                       class="form-control"
                       autocomplete="email"
                       required
                       autofocus/>
            </div>

            <div class="form-group">
                <label for="password" class="form-label required">Votre mot de passe</label>
                <input type="password"
                       name="_password"
                       id="password"
                       class="form-control"
                       autocomplete="current-password"
                       required/>
            </div>
        </fieldset>

        <fieldset class="form-fieldset controls">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}"/>
            <p>
                <button class="form-submit cta" type="submit">Connexion</button>
            </p>
            <p>
                <a href="{{ path('app_register') }}" class="app-button outline">
                    <small>Pas de compte ?</small>
                    Inscription
                </a>
            </p>
        </fieldset>
    </form>
{% endblock %}
